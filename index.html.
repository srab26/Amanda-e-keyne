<script>
  const WEDDING_DATE = new Date('2026-09-26T11:00:00');

  function updateCountdown() {
    const now = new Date();
    const diff = WEDDING_DATE - now;
    const el = document.getElementById('countdown');

    if (diff <= 0) {
      el.innerHTML = '<p class="countdown-past">Hoje é o grande dia!</p>';
      return;
    }

    const days  = Math.floor(diff / (1000 * 60 * 60 * 24));
    const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    const mins  = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
    const secs  = Math.floor((diff % (1000 * 60)) / 1000);

    function unit(n, label) {
      return `<div class="count-unit">
        <div class="count-number">${String(n).padStart(2,'0')}</div>
        <div class="count-label">${label}</div>
      </div>`;
    }

    el.innerHTML =
      unit(days,  'dias') +
      '<span class="count-sep">:</span>' +
      unit(hours, 'horas') +
      '<span class="count-sep">:</span>' +
      unit(mins,  'min') +
      '<span class="count-sep">:</span>' +
      unit(secs,  'seg');
  }

  updateCountdown();
  setInterval(updateCountdown, 1000);
</script>
