<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Amanda & Keyne — Casamento</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --off-white: #F8F5EF;
    --cream: #EDE8DF;
    --gold: #B89A6A;
    --gold-light: #D4B896;
    --olive: #6B7A52;
    --moss: #4E5E3A;
    --beige: #C8B99A;
    --text-dark: #3A3228;
    --text-mid: #6B6058;
    --text-light: #9A8E82;
  }

  html { scroll-behavior: smooth; }

  body {
    background-color: var(--off-white);
    color: var(--text-dark);
    font-family: 'Jost', sans-serif;
    font-weight: 300;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── FLORAL CORNERS ── */
  .corner {
    position: fixed;
    width: 260px;
    height: 260px;
    z-index: 0;
    pointer-events: none;
  }
  .corner svg { width: 100%; height: 100%; }
  .corner-tl { top: 0; left: 0; }
  .corner-tr { top: 0; right: 0; transform: scaleX(-1); }
  .corner-bl { bottom: 0; left: 0; transform: scaleY(-1); }
  .corner-br { bottom: 0; right: 0; transform: scale(-1); }

  @media (max-width: 600px) {
    .corner { width: 155px; height: 155px; }
  }

  /* ── WRAPPER ── */
  .wrapper {
    position: relative;
    z-index: 1;
    max-width: 760px;
    margin: 0 auto;
    padding: 80px 32px 80px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* ── HEADER ── */
  .invite-header {
    text-align: center;
    opacity: 0;
    transform: translateY(18px);
    animation: fadeUp 1.1s ease forwards 0.2s;
  }

  .eyebrow {
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    font-size: 0.7rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 20px;
  }

  .names {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3.2rem, 10vw, 5.8rem);
    font-weight: 300;
    line-height: 1;
    color: var(--text-dark);
    letter-spacing: 0.01em;
  }

  .ampersand {
    color: var(--olive);
    font-style: italic;
    font-weight: 300;
  }

  /* ── DIVIDER ── */
  .divider-line {
    display: flex;
    align-items: center;
    gap: 16px;
    margin: 28px auto;
    width: 260px;
    opacity: 0;
    animation: fadeIn 1s ease forwards 0.7s;
  }
  .divider-line span {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--gold-light), transparent);
  }
  .divider-line svg { flex-shrink: 0; }

  /* ── TAGLINE ── */
  .tagline {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: clamp(1.05rem, 3vw, 1.3rem);
    color: var(--text-mid);
    font-weight: 300;
    line-height: 1.6;
    max-width: 460px;
    text-align: center;
    margin: 0 auto;
    opacity: 0;
    animation: fadeUp 1s ease forwards 0.9s;
  }

  /* ── BIBLE VERSE (top) ── */
  .bible-verse {
    margin-top: 32px;
    text-align: center;
    opacity: 0;
    animation: fadeUp 1s ease forwards 1.05s;
    max-width: 420px;
  }
  .bible-text {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: clamp(0.88rem, 2.4vw, 1.0rem);
    color: var(--text-light);
    line-height: 1.8;
    font-weight: 300;
  }
  .bible-ref {
    display: block;
    margin-top: 6px;
    font-family: 'Jost', sans-serif;
    font-size: 0.58rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 400;
  }

  /* ── EVENT DETAILS ── */
  .event-details {
    margin-top: 44px;
    display: flex;
    gap: 0;
    justify-content: center;
    opacity: 0;
    animation: fadeUp 1s ease forwards 1.2s;
  }

  .detail-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 36px;
    position: relative;
  }

  .detail-block + .detail-block::before {
    content: '';
    position: absolute;
    left: 0;
    top: 12%;
    height: 76%;
    width: 1px;
    background: var(--beige);
  }

  .detail-label {
    font-size: 0.62rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 6px;
    font-weight: 400;
  }

  .detail-value {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.05rem, 2.8vw, 1.25rem);
    font-weight: 400;
    color: var(--text-dark);
    text-align: center;
    line-height: 1.4;
  }

  /* ── CARDS ── */
  .cards-section {
    margin-top: 64px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    width: 100%;
    opacity: 0;
    animation: fadeUp 1s ease forwards 1.5s;
  }

  @media (max-width: 600px) {
    .cards-section {
      grid-template-columns: 1fr;
      gap: 14px;
    }
  }

  .card {
    background: #FFFFFF;
    border: 1px solid var(--cream);
    border-radius: 2px;
    padding: 32px 20px 28px;
    text-align: center;
    text-decoration: none;
    color: var(--text-dark);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    cursor: pointer;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(184,154,106,0.04) 0%, transparent 60%);
    pointer-events: none;
  }

  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(107,122,82,0.12), 0 2px 8px rgba(0,0,0,0.04);
    border-color: var(--gold-light);
  }

  /* Minimalist SVG icon wrapper */
  .card-icon {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--olive);
  }
  .card-icon svg {
    width: 22px;
    height: 22px;
    stroke: var(--olive);
    fill: none;
    stroke-width: 1.3;
    stroke-linecap: round;
    stroke-linejoin: round;
    transition: stroke 0.3s ease;
  }
  .card:hover .card-icon svg { stroke: var(--gold); }

  .card-title {
    font-size: 0.6rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 500;
    font-family: 'Jost', sans-serif;
  }

  .card-desc {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.05rem;
    font-style: italic;
    color: var(--text-mid);
    line-height: 1.5;
    font-weight: 300;
  }

  .card-deadline {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1rem;
    font-style: italic;
    font-weight: 400;
    color: var(--moss);
    letter-spacing: 0.04em;
    border-top: 1px solid var(--beige);
    padding-top: 10px;
    width: 100%;
    text-align: center;
  }

  .card-arrow {
    margin-top: 6px;
    width: 28px;
    height: 1px;
    background: var(--gold-light);
    transition: width 0.3s ease;
    position: relative;
  }
  .card-arrow::after {
    content: '';
    position: absolute;
    right: 0;
    top: -3px;
    width: 7px;
    height: 7px;
    border-right: 1px solid var(--gold-light);
    border-top: 1px solid var(--gold-light);
    transform: rotate(45deg);
  }
  .card:hover .card-arrow { width: 40px; }

  /* ── CLOSING ── */
  .closing {
    margin-top: 64px;
    text-align: center;
    opacity: 0;
    animation: fadeUp 1s ease forwards 1.8s;
    max-width: 440px;
  }

  .closing-text {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.1rem, 3.2vw, 1.45rem);
    font-style: italic;
    font-weight: 300;
    color: var(--text-mid);
    line-height: 1.7;
  }


  /* ── RSVP DEADLINE ── */
  .rsvp-deadline {
    margin-top: 36px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    opacity: 0;
    animation: fadeUp 1s ease forwards 1.9s;
  }

  .rsvp-line {
    width: 140px;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--gold-light), transparent);
  }

  .rsvp-label {
    font-family: 'Jost', sans-serif;
    font-size: 0.6rem;
    font-weight: 400;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--gold);
  }

  .rsvp-date {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1rem, 2.8vw, 1.2rem);
    font-weight: 400;
    color: var(--text-dark);
  }

  /* ── SECOND VERSE ── */
  .verse-bottom {
    margin-top: 40px;
    text-align: center;
    opacity: 0;
    animation: fadeUp 1s ease forwards 1.95s;
    max-width: 380px;
  }

  /* ── COUNTDOWN ── */
  .countdown-section {
    margin-top: 52px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    opacity: 0;
    animation: fadeUp 1s ease forwards 2.1s;
  }

  .countdown-label {
    font-size: 0.6rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 400;
    margin-bottom: 20px;
  }

  .countdown-grid {
    display: flex;
    gap: 6px;
    align-items: flex-start;
  }

  .count-unit {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .count-number {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 6vw, 3rem);
    font-weight: 300;
    color: var(--text-dark);
    line-height: 1;
    min-width: 60px;
    text-align: center;
    background: #fff;
    border: 1px solid var(--cream);
    padding: 10px 6px 8px;
  }

  .count-label {
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-light);
    font-weight: 400;
  }

  .count-sep {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.8rem, 5vw, 2.6rem);
    font-weight: 300;
    color: var(--beige);
    line-height: 1;
    padding-top: 10px;
    align-self: flex-start;
  }

  .countdown-past {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 1.1rem;
    color: var(--olive);
  }

  /* ── FOOTER ── */
  .footer {
    margin-top: 64px;
    text-align: center;
    opacity: 0;
    animation: fadeIn 1s ease forwards 2.4s;
  }

  .footer-monogram {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.6rem;
    color: var(--beige);
    font-weight: 300;
    letter-spacing: 0.1em;
  }

  /* ── ANIMATIONS ── */
  @keyframes fadeUp {
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn {
    to { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    * { animation-duration: 0.01ms !important; }
  }

  @media (max-width: 480px) {
    .wrapper { padding: 64px 20px 64px; }
    .detail-block { padding: 0 20px; }
    .count-number { min-width: 46px; padding: 8px 4px 6px; }
  }
</style>
</head>
